            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Denia#9876"
                android:textSize="18sp" />
        </LinearLayout>
        -->
    </LinearLayout>

    <!-- Start Match Button -->
    <Button
        android:id="@+id/startMatchButton"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/kc_dark_grey"
        android:textColor="@android:color/white"
        android:text="Start Match"
        app:layout_constraintTop_toBottomOf="@id/currentRoomBox"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Available Player Label -->
    <TextView
        android:id="@+id/availablePlayersLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/black"
        android:text="Available Players"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/startMatchButton"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Available Player Box -->
    <LinearLayout
        android:id="@+id/availablePlayersBox"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@android:drawable/dialog_holo_light_frame"
        app:layout_constraintTop_toBottomOf="@id/availablePlayersLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <!-- statisch für den ersten Look
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
