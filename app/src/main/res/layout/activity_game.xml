<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gameRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kc_background"
    tools:context=".ui.GameActivity">

    <HorizontalScrollView
        android:id="@+id/opponentHandScrollView"
        android:layout_width="300dp"
        android:layout_height="104dp"
        android:background="@color/kc_dark_grey"
        android:padding="8dp"
        android:scrollbars="none"
        android:fillViewport="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:id="@+id/opponentHandContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/opponentScoreText"
        android:layout_width="96dp"
        android:layout_height="28dp"
        android:background="@color/kc_guest"
        android:gravity="center"
        android:text="0"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/opponentHandScrollView"
        app:layout_constraintStart_toStartOf="@id/opponentHandScrollView"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:id="@+id/roundResultContainer"
        android:layout_width="112dp"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="@android:color/black"
        android:padding="2dp"
        app:layout_constraintTop_toBottomOf="@id/opponentScoreText"
        app:layout_constraintEnd_toEndOf="@id/boardContainer"
        android:layout_marginTop="28dp" />

    <GridLayout
        android:id="@+id/boardContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:columnCount="3"
        android:rowCount="3"
        android:background="@color/kc_dark_grey"
        android:padding="0dp"
        app:layout_constraintTop_toBottomOf="@id/roundResultContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/playerScoreText"
        android:layout_width="96dp"
        android:layout_height="28dp"
        android:background="@color/kc_host"
        android:gravity="center"
        android:text="13"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/boardContainer"
        app:layout_constraintEnd_toEndOf="@id/playerHandScrollView"
        android:layout_marginTop="36dp" />

    <HorizontalScrollView
        android:id="@+id/playerHandScrollView"
        android:layout_width="300dp"
        android:layout_height="104dp"
        android:background="@color/kc_dark_grey"
        android:padding="8dp"
        android:scrollbars="horizontal"
        android:fillViewport="false"
        app:layout_constraintTop_toBottomOf="@id/playerScoreText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/playerHandContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/turnInfoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#AA7D758D"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="Your Turn"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/boardContainer"
        app:layout_constraintBottom_toBottomOf="@id/boardContainer"
        app:layout_constraintStart_toStartOf="@id/boardContainer"
        app:layout_constraintEnd_toEndOf="@id/boardContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>