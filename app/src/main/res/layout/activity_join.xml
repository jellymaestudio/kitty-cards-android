<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/joinRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kc_background"
    tools:context=".ui.JoinActivity">

    <TextView
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/kc_back_button_background"
        android:text="‹"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:clickable="true"
        android:focusable="true"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/joinTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Game"
        android:textColor="@android:color/black"
        android:textSize="30sp"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintStart_toEndOf="@id/backButton"
        android:layout_marginStart="28dp" />

    <TextView
        android:id="@+id/roomLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Room"
        android:textColor="@android:color/black"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp" />

    <LinearLayout
        android:id="@+id/roomBox"
        android:layout_width="0dp"
        android:layout_height="132dp"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/roomLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:id="@+id/roomPlayersContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical" />

    </LinearLayout>

    <TextView
        android:id="@+id/availableRoomsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Available Rooms"
        android:textColor="@android:color/black"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/roomBox"
        app:layout_constraintStart_toStartOf="@id/roomBox"
        android:layout_marginTop="112dp" />

    <ScrollView
        android:id="@+id/availableRoomsScrollView"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@android:color/white"
        android:padding="8dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/availableRoomsLabel"
        app:layout_constraintStart_toStartOf="@id/roomBox"
        app:layout_constraintEnd_toEndOf="@id/roomBox"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:id="@+id/availableRoomsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>